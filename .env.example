# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# Web portal
PUBLIC_BASE_URL=https://omnisaver.example.com
SESSION_CONNECT_TOKEN_TTL_SECONDS=600

# Database
POSTGRES_DB=omnisaver
POSTGRES_USER=omnisaver
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://omnisaver:change-me@postgres:5432/omnisaver

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SESSION_VAULT_MASTER_KEY_BASE64=change-me
COOKIE_ENCRYPTION_KEY_ID=default

# Storage
DOWNLOAD_STORAGE_PATH=/app/storage/downloads
MAX_DOWNLOAD_SIZE_MB=2000
TEMP_FILE_TTL_HOURS=24

# Downloader engines
YTDLP_BIN=yt-dlp
GALLERY_DL_BIN=gallery-dl
FFMPEG_BIN=ffmpeg

# Runtime
LOG_LEVEL=INFO
ENVIRONMENT=production
